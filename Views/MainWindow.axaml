<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:chatstar.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="chatstar.Views.MainWindow"
        Title="ChatStar" Height="450" Width="550"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *, Auto" ColumnDefinitions="*, 150" Margin="10">
        
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,15">
            <TextBlock Text="My Name:" VerticalAlignment="Center" FontSize="12"/>
            <TextBox Text="{Binding MyUserName}" Width="100" Watermark="Name"/>
            <Separator Width="10" Background="Transparent"/>
            <TextBox Text="{Binding TargetIp}" Width="120" Watermark="IP Address"/>
            <Button Content="Host" Command="{Binding StartServerCommand}" Background="DarkGreen" Foreground="White"/>
            <Button Content="Join" Command="{Binding ConnectCommand}" Background="DarkBlue" Foreground="White"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5">
            <ListBox ItemsSource="{Binding ChatHistory}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <TextBlock Text="{Binding Time}" Foreground="Gray" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding User}" Foreground="CornflowerBlue" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Text=": "/>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="10,0,0,0" Padding="12" Background="#F8F9FA" CornerRadius="5" BorderBrush="#EEEEEE" BorderThickness="1">
            <StackPanel Spacing="10">
                <TextBlock Text="PARTNER" FontSize="10" FontWeight="Bold" Foreground="Gray"/>
                <TextBlock Text="{Binding RemotePartnerName}" FontWeight="Bold" Foreground="DarkGreen" TextWrapping="Wrap"/>
                
                <Separator Height="1" Background="#DDDDDD"/>
                
                <TextBlock Text="CONNECTION" FontSize="10" FontWeight="Bold" Foreground="Gray"/>
                <TextBlock Text="{Binding TargetIp}" FontSize="12"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0" Text="{Binding NewMessageText}" Watermark="Type a message..." AcceptsReturn="False"/>
                <Button Grid.Column="1" Content="Send" Command="{Binding SendMessageCommand}" IsDefault="True" Margin="8,0,0,0" Width="80"/>
            </Grid>
            <TextBlock Text="{Binding StatusText}" Foreground="#888888" FontSize="11" FontStyle="Italic" Margin="2,5,0,0"/>
        </StackPanel>
        
    </Grid>
</Window>