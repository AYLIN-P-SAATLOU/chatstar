<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:chatstar.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="chatstar.Views.MainWindow"
        Title="ChatStar" Height="450" Width="400">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10">
            <TextBox Watermark="Enter IP" Text="{Binding TargetIp}" Width="150"/>
            <Button Content="Host" Command="{Binding StartServerCommand}" Background="DarkGreen"/>
            <Button Content="Join" Command="{Binding ConnectCommand}" Background="DarkBlue"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding ChatHistory}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding User}" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock Text=": "/>
                        <TextBlock Text="{Binding Text}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,10,0,0">
            <TextBox Grid.Column="0" Text="{Binding NewMessageText}" Watermark="Type here..."/>
            <Button Grid.Column="1" Content="Send" Command="{Binding SendMessageCommand}" Margin="5,0,0,0"/>
        </Grid>
        
    </Grid>
</Window>