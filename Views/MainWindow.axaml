<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:chatstar.ViewModels"
        x:Class="chatstar.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ChatStar"
        Width="400"
        Height="600"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="*, Auto" Margin="15">
    
    <Border Grid.Row="0" Background="#2b2b2b" CornerRadius="10" Padding="5">
      <ListBox ItemsSource="{Binding ChatHistory}" 
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="5">
              <TextBlock Text="{Binding User}" FontSize="10" Foreground="Gray" />
              <Border Background="#3e3e3e" Padding="10" CornerRadius="8">
                <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
      <TextBox Grid.Column="0" 
               Text="{Binding NewMessageText}" 
               Watermark="Type a message..." 
               Margin="0,0,10,0"/>
      <Button Grid.Column="1" 
              Content="Send" 
              Command="{Binding SendMessageCommand}" 
              Padding="15,5"/>
    </Grid>

  </Grid>
</Window>